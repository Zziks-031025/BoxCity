page {
  --primary-color: #e97840;
  --primary-dark: #cb582d;
  --primary-deep: #9e4623;
  --primary-soft: #fff1e3;
  --primary-soft-strong: #ffe4c9;
  --accent-color: #f4bf78;
  --accent-soft: #fff6dc;
  --bg-color: #f6efe6;
  --bg-soft: #fbf7f1;
  --bg-hero: #fff8ee;
  --surface-color: #fffdf9;
  --surface-strong: #ffffff;
  --text-color: #2f251f;
  --text-secondary: #8a7667;
  --text-tertiary: #baa595;
  --border-color: #f0e2d4;
  --success-color: #2f9b6d;
  --info-color: #4f82c9;
  --danger-color: #d96c56;
  --shadow-soft: 0 16rpx 40rpx rgba(116, 79, 50, 0.08);
  --shadow-floating: 0 20rpx 48rpx rgba(226, 140, 82, 0.16);
  --shadow-card-strong: 0 24rpx 56rpx rgba(130, 88, 55, 0.12);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-pill: 999rpx;

  font-size: 28rpx;
  line-height: 1.45;
  color: var(--text-color);
  background: var(--bg-color);
  box-sizing: border-box;

  --button-default-background-color: #fffdf9;
  --button-default-border-color: #eddac8;
  --button-default-color: var(--text-color);
  --button-danger-background-color: linear-gradient(135deg, #ed7f46, #f3a763);
  --button-danger-border-color: transparent;
  --button-danger-color: #ffffff;
  --button-warning-background-color: linear-gradient(135deg, #f2b252, #f6cd87);
  --button-warning-border-color: transparent;
  --button-warning-color: #7f4b1c;
  --button-primary-background-color: linear-gradient(135deg, #ed7f46, #f3a763);
  --button-primary-border-color: transparent;
  --button-primary-color: #ffffff;
  --button-border-radius: 999rpx;

  --checkbox-checked-icon-color: var(--primary-color);
  --tabs-bottom-bar-color: var(--primary-color);
  --tabs-title-text-color: var(--text-secondary);
  --tabs-active-title-color: var(--primary-color);
  --tabs-line-height: 44px;
  --tab-text-color: var(--text-secondary);
  --tab-active-text-color: var(--primary-color);
  --cell-background-color: #fffdf9;
  --cell-group-background-color: transparent;
  --cell-text-color: var(--text-color);
  --cell-value-color: var(--text-secondary);
  --cell-label-color: var(--text-secondary);
  --cell-border-color: var(--border-color);
  --field-input-text-color: var(--text-color);
  --field-placeholder-text-color: var(--text-tertiary);
  --search-background-color: transparent;
  --search-content-background-color: rgba(255, 255, 255, 0.92);
  --search-label-color: var(--text-secondary);
  --search-left-icon-color: var(--text-tertiary);
  --search-action-text-color: var(--primary-color);
  --search-padding: 18rpx 20rpx;
  --switch-on-background-color: var(--primary-color);
  --radio-checked-icon-color: var(--primary-color);
  --rate-icon-full-color: var(--primary-color);
  --rate-icon-void-color: #e6d4c4;
  --popup-background-color: #fffdf9;
  --dialog-background-color: #fffdf9;
  --sidebar-width: 176rpx;
  --sidebar-selected-text-color: var(--primary-color);
  --sidebar-selected-border-color: var(--primary-color);
  --sidebar-background-color: transparent;
  --sidebar-selected-background-color: rgba(255, 255, 255, 0.94);
  --sidebar-text-color: var(--text-secondary);
  --sidebar-padding: 0;
}

view,
text,
scroll-view,
swiper,
swiper-item {
  box-sizing: border-box;
}

image {
  display: block;
}

.flex {
  display: flex;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.items-end {
  align-items: flex-end;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.justify-end {
  justify-content: flex-end;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-bold {
  font-weight: 700;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.p-20 {
  padding: 20rpx;
}

.m-20 {
  margin: 20rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.ml-20 {
  margin-left: 20rpx;
}

.mr-20 {
  margin-right: 20rpx;
}

.container {
  padding: 24rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.card,
.section,
.section-card,
.order-card,
.review-card,
.desc-card,
.info-card,
.merchant-card,
.top-card,
.track-card,
.shop-card,
.address-item,
.bind-form,
.order-list-box {
  background: rgba(255, 253, 249, 0.98);
  border: 1rpx solid rgba(239, 226, 212, 0.92);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
}

.goods-card {
  background: linear-gradient(180deg, #fffefb 0%, #fff8f1 100%);
  border: 1rpx solid rgba(240, 223, 204, 0.92);
  border-radius: 24rpx;
  box-shadow: var(--shadow-soft);
}

.section-header,
.card-title-row,
.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-title,
.card-title,
.title {
  color: var(--text-color);
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.section-subtitle,
.card-subtitle,
.caption-text {
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.section-eyebrow,
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 241, 227, 0.96);
  color: var(--primary-color);
  font-size: 22rpx;
  font-weight: 700;
}

.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 20rpx 0;
}

.price,
.goods-price,
.total-price,
.price-total,
.submit-price {
  color: var(--primary-color);
  font-weight: 700;
}

.btn-primary {
  background: linear-gradient(135deg, #ed7f46, #f3a763);
  color: #ffffff;
  border: none;
  border-radius: 999rpx;
  padding: 18rpx 34rpx;
  font-size: 28rpx;
  box-shadow: var(--shadow-floating);
}

.btn-secondary {
  background: rgba(255, 248, 241, 0.95);
  color: var(--primary-color);
  border: 1rpx solid rgba(233, 177, 126, 0.85);
  border-radius: 999rpx;
  padding: 18rpx 34rpx;
  font-size: 28rpx;
}

.action-btn,
.footer-action-btn,
.submit-action-btn,
.order-list-btn,
.order-action-btn,
.after-action-btn,
.bottom-action-btn,
.review-submit-btn,
.profile-save-btn,
.result-btn,
.wx-login-btn,
.bind-btn,
.empty-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  white-space: nowrap;
}

.search-bar,
.search-input-wrap {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(239, 226, 212, 0.95);
  box-shadow: var(--shadow-soft);
}

.keyword-tag,
.sub-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-soft);
  border: 1rpx solid rgba(236, 204, 172, 0.9);
  color: var(--text-secondary);
}

.sub-tag-active,
.keyword-tag-hot,
.filter-item-active {
  color: #ffffff;
  background: linear-gradient(135deg, #ea7d46, #f2ad64);
  border-color: transparent;
  box-shadow: var(--shadow-floating);
}

.load-more-text,
.no-more,
.clear-text,
.goods-sales,
.goods-spec,
.meta-item,
.meta-row,
.price-label,
.price-value,
.info-label,
.info-value,
.desc-text,
.addr-detail,
.status-desc,
.track-time,
.result-desc {
  color: var(--text-secondary);
}

.page-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(255, 221, 188, 0.55) 0, rgba(255, 221, 188, 0) 32%),
    linear-gradient(180deg, #fff8ee 0%, var(--bg-color) 24%, var(--bg-color) 100%);
}

.page-content {
  padding: 0 20rpx 48rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 30rpx;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)) top right / 220rpx 220rpx no-repeat,
    linear-gradient(145deg, #dd7541 0%, #ea9056 52%, #f3bf75 100%);
  box-shadow: var(--shadow-floating);
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -70rpx;
  top: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 249, 242, 0.9);
}

.pill-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 22rpx;
}

.price-symbol {
  font-size: 24rpx;
  margin-right: 4rpx;
}

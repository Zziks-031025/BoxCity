.shop-page {
  min-height: 100vh;
  padding: calc(20rpx + env(safe-area-inset-top)) 20rpx 32rpx;
}

.shop-hero,
.shop-card,
.goods-card {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.shop-hero {
  display: flex;
  gap: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)) top right / 220rpx 220rpx no-repeat,
    linear-gradient(145deg, #dd7541 0%, #ea8f57 54%, #f1b76f 100%);
  color: #fff;
  box-shadow: var(--shadow-floating);
}

.shop-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.24);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.shop-main {
  flex: 1;
}

.shop-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.shop-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 249, 242, 0.9);
}

.shop-intro {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 249, 242, 0.88);
}

.hero-pills {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.card-text,
.meta-row {
  font-size: 24rpx;
  line-height: 1.7;
}

.card-text {
  color: var(--text-secondary);
}

.meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border-color);
}

.meta-label {
  flex-shrink: 0;
}

.meta-value {
  flex: 1;
  text-align: right;
  line-height: 1.6;
}

.meta-row:last-of-type {
  border-bottom: none;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.goods-item {
  background: linear-gradient(180deg, #fff9f3 0%, #fffefb 100%);
  border: 1rpx solid rgba(236, 218, 199, 0.9);
  border-radius: 22rpx;
  padding: 16rpx;
}

.goods-title {
  display: block;
  min-height: 74rpx;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--text-color);
  line-height: 1.5;
}

.goods-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 700;
}

.goods-sales {
  font-size: 22rpx;
  color: var(--text-secondary);
}

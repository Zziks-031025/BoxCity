@import "../../styles/commercialization.wxss";

.confirm-page {
  min-height: 100vh;
  padding-bottom: 226rpx;
}

.section {
  margin: 18rpx 20rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 18rpx;
}

.merchant-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.merchant-total {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  font-size: 23rpx;
  color: var(--primary-color);
}

.address-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #fffefb 100%);
}

.addr-info {
  flex: 1;
}

.addr-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.addr-name {
  font-size: 31rpx;
  font-weight: 700;
  color: var(--text-color);
}

.addr-phone {
  font-size: 27rpx;
  color: var(--text-secondary);
}

.addr-detail {
  font-size: 26rpx;
  line-height: 1.7;
}

.addr-empty {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
}

.addr-empty-text {
  font-size: 27rpx;
  color: var(--text-secondary);
}

.goods-section {
  padding-bottom: 14rpx;
}

.goods-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #fffefb 100%);
  border: 1rpx solid rgba(239, 226, 212, 0.92);
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.goods-name {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.55;
}

.goods-policy {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fbf4ec;
  color: #9a6d2d;
  font-size: 20rpx;
  font-weight: 600;
}

.goods-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.goods-price {
  font-size: 30rpx;
}

.goods-qty {
  font-size: 25rpx;
  color: var(--text-secondary);
}

.merchant-summary {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 14rpx;
  padding: 16rpx 18rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-top: 1rpx solid var(--border-color);
}

.merchant-summary-item {
  line-height: 1.6;
}

.order-note {
  margin-top: 18rpx;
}

.rule-section {
  padding-bottom: 28rpx;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rule-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary-soft);
  color: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.support-inline {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.support-inline-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.support-inline-link {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.price-section {
  padding: 20rpx 28rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.price-label {
  font-size: 27rpx;
}

.price-value {
  font-size: 27rpx;
  color: var(--text-color);
}

.total-row {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.price-total {
  font-size: 36rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 249, 0.98);
  border-top: 1rpx solid rgba(238, 225, 211, 0.98);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.submit-total {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.submit-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.submit-price {
  font-size: 38rpx;
}

.submit-action-btn {
  width: 240rpx !important;
  min-width: 240rpx !important;
  flex: 0 0 240rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

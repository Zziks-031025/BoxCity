@import "../../styles/commercialization.wxss";

.detail-page {
  min-height: 100vh;
  padding-bottom: 226rpx;
}

.status-banner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin: 20rpx 20rpx 0;
  padding: 42rpx 34rpx;
  color: #fff;
  border-radius: 34rpx;
  box-shadow: var(--shadow-floating);
}

.status-bg-0 {
  background: linear-gradient(135deg, #e87b45, #f2ae67);
}

.status-bg-1 {
  background: linear-gradient(135deg, #de7f47, #f1ab63);
}

.status-bg-2 {
  background: linear-gradient(135deg, #d59248, #f2ba6d);
}

.status-bg-3 {
  background: linear-gradient(135deg, #8c7a6d, #b0a092);
}

.status-bg-4 {
  background: linear-gradient(135deg, #aa988d, #c1b4ab);
}

.status-bg-5 {
  background: linear-gradient(135deg, #d36b5f, #e89a75);
}

.status-icon {
  display: block;
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 48rpx;
  margin-bottom: 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.18);
}

.status-text {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.status-desc {
  font-size: 25rpx;
  line-height: 1.6;
  color: rgba(255, 248, 241, 0.88);
}

.section {
  margin: 18rpx 20rpx 0;
  padding: 26rpx;
  border-radius: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.addr-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.addr-name {
  font-size: 31rpx;
  font-weight: 700;
  color: var(--text-color);
}

.addr-phone {
  font-size: 27rpx;
  color: var(--text-secondary);
}

.addr-detail {
  font-size: 26rpx;
  line-height: 1.7;
}

.goods-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #fffefb 100%);
  border: 1rpx solid rgba(239, 226, 212, 0.92);
}

.goods-row:last-child {
  margin-bottom: 0;
}

.goods-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.goods-name {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.55;
}

.goods-policy {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fbf4ec;
  color: #9a6d2d;
  font-size: 20rpx;
  font-weight: 600;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-price {
  font-size: 30rpx;
}

.goods-qty {
  font-size: 25rpx;
  color: var(--text-secondary);
}

.logistics-info {
  padding: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff8ef 0%, #fffefb 100%);
  border: 1rpx solid rgba(235, 211, 185, 0.95);
}

.logistics-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 10rpx 0;
}

.logistics-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.logistics-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-color);
  line-height: 1.6;
  text-align: right;
}

.order-note {
  margin-top: 18rpx;
}

.rule-list,
.support-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rule-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary-soft);
  color: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.support-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #fffefb 100%);
  border: 1rpx solid rgba(239, 226, 212, 0.92);
}

.support-main {
  flex: 1;
  min-width: 0;
}

.support-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--text-color);
}

.support-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.price-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
}

.price-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 27rpx;
}

.price-value {
  flex: 1;
  font-size: 27rpx;
  color: var(--text-color);
  text-align: right;
}

.total-row {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.price-total {
  font-size: 36rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 140rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-color);
  text-align: right;
  line-height: 1.5;
}

.info-value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  min-width: 0;
}

.copy-btn {
  font-size: 22rpx;
  color: var(--primary-color);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  border: 1rpx solid rgba(229, 177, 127, 0.85);
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 249, 0.98);
  border-top: 1rpx solid rgba(238, 225, 211, 0.98);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.order-action-item {
  width: 100%;
}

.order-action-item-span {
  grid-column: 1 / -1;
}

.order-action-btn {
  width: 100% !important;
  min-width: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

<view class="page-shell order-list-page">
  <view class="order-hero-wrap">
    <view class="hero-card order-hero">
      <text class="hero-title">{{currentTabLabel}}订单</text>
      <text class="hero-subtitle">在这里查看付款、发货、收货、核销和评价进度，重要状态一眼就能看到。</text>
    </view>
  </view>

  <view class="tabs-wrap">
    <van-tabs active="{{activeTab}}" color="#FF6B35" title-active-color="#FF6B35" sticky bind:change="onTabChange">
      <van-tab wx:for="{{tabs}}" wx:key="status" title="{{item.label}}"></van-tab>
    </van-tabs>
  </view>

  <block wx:if="{{orderList.length > 0}}">
    <block wx:for="{{orderList}}" wx:key="orderNo" wx:for-item="order">
      <view class="order-card">
        <view class="order-header">
          <view class="shop-info">
            <van-icon name="shop-o" size="14px" color="#FF6B35" />
            <text class="shop-name">{{order.shopName || '品质店铺'}}</text>
          </view>
          <text class="order-status {{order.statusClass}}">{{order.statusText}}</text>
        </view>

        <view class="order-desc-row">
          <text class="order-desc">{{order.statusDesc}}</text>
          <text class="order-time" wx:if="{{order.createTimeText}}">{{order.createTimeText}}</text>
        </view>

        <view class="order-goods" bindtap="goDetail" data-order-no="{{order.orderNo}}">
          <block wx:for="{{order.orderItems}}" wx:key="id">
            <view class="goods-row">
              <van-image src="{{item.imageUrl}}" width="80rpx" height="80rpx" radius="18rpx" fit="cover" />
              <view class="goods-meta">
                <text class="goods-name text-ellipsis-2">{{item.goodsName}}</text>
                <text class="goods-fulfillment">{{item.goodsPolicyText}}</text>
              </view>
              <text class="goods-qty">x{{item.quantity}}</text>
            </view>
          </block>
        </view>

        <view class="ios-inline-note" wx:if="{{order.iosPurchaseBlocked}}">
          <text>{{order.iosRestrictionText}}</text>
        </view>

        <view class="order-total">
          <text class="total-text">共 {{order.totalCount || 1}} 件商品，实付</text>
          <text class="total-price">¥{{order.payAmount}}</text>
        </view>

        <view class="order-actions">
          <block wx:if="{{order.status === 0}}">
            <view class="order-action-item">
              <van-button custom-class="order-list-btn" size="mini" plain data-order-no="{{order.orderNo}}" bindtap="cancelOrder">取消订单</van-button>
            </view>
            <view class="order-action-item">
              <van-button wx:if="{{!order.iosPurchaseBlocked}}" custom-class="order-list-btn" size="mini" type="danger" data-order-no="{{order.orderNo}}" bindtap="goPay">去支付</van-button>
              <van-button wx:else custom-class="order-list-btn" size="mini" plain disabled>iOS 端暂不支持该权益购买</van-button>
            </view>
          </block>
          <block wx:elif="{{order.status === 1}}">
            <view class="order-action-item">
              <van-button custom-class="order-list-btn" size="mini" plain data-order-no="{{order.orderNo}}" bindtap="remindShip">提醒发货</van-button>
            </view>
          </block>
          <block wx:elif="{{order.status === 2}}">
            <view class="order-action-item">
              <van-button custom-class="order-list-btn" size="mini" type="danger" data-order-no="{{order.orderNo}}" bindtap="confirmReceive">确认收货</van-button>
            </view>
          </block>
          <block wx:elif="{{order.status === 3}}">
            <view class="order-action-item">
              <van-button custom-class="order-list-btn" size="mini" plain data-order-no="{{order.orderNo}}" bindtap="deleteOrder">删除</van-button>
            </view>
            <view class="order-action-item">
              <van-button custom-class="order-list-btn" size="mini" type="warning" data-order-no="{{order.orderNo}}" bindtap="goReview" disabled="{{order.reviewed}}">
                {{order.reviewed ? '已评价' : '去评价'}}
              </van-button>
            </view>
          </block>
          <view class="order-action-item {{order.status === 0 || order.status === 3 || order.status === 4 || order.status === 5 ? 'order-action-item-span' : ''}}">
            <van-button custom-class="order-list-btn" size="mini" plain data-order-no="{{order.orderNo}}" bindtap="goDetail">查看详情</van-button>
          </view>
        </view>
      </view>
    </block>

    <view class="load-more" wx:if="{{!hasMore}}">
      <text class="load-more-text">没有更多订单了</text>
    </view>
  </block>

  <block wx:elif="{{!loading}}">
    <van-empty description="当前没有对应订单" />
  </block>
</view>

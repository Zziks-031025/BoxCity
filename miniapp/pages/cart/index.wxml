<!-- 购物车页面模板 -->
<!-- 整体结构：顶部标题+统计 → 空状态/商品列表 → 底部操作栏 -->
<view class="page-shell cart-page">
  <!-- 顶部区域：标题、编辑按钮、统计卡片 -->
  <view class="cart-hero">
    <view class="cart-head">
      <view>
        <text class="cart-title">购物车</text>
        <text class="cart-subtitle">把喜欢的商品先收进来，再一起结算</text>
      </view>
      <!-- 编辑/完成切换按钮：控制编辑模式 -->
      <text class="edit-btn" bindtap="toggleEditing">{{editing ? '完成' : '编辑'}}</text>
    </view>

    <!-- 统计卡片：显示商品数、已选条目数、当前合计金额 -->
    <view class="cart-summary-card">
      <view class="summary-item">
        <text class="summary-value">{{itemCount}}</text>
        <text class="summary-label">购物车商品</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{selectedLineCount}}</text>
        <text class="summary-label">已选条目</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">¥{{totalPrice}}</text>
        <text class="summary-label">当前合计</text>
      </view>
    </view>
  </view>

  <!-- 购物车为空时的提示 -->
  <block wx:if="{{cartList.length === 0}}">
    <view class="empty-shell">
      <van-empty description="购物车还是空的，先去挑点喜欢的吧" image="cart">
        <van-button round type="danger" custom-class="empty-btn" bindtap="goShopping">去逛逛</van-button>
      </van-empty>
    </view>
  </block>

  <!-- 购物车商品列表：按商家分组展示 -->
  <scroll-view scroll-y class="cart-scroll" wx:else>
    <view class="page-content cart-content">
      <!-- 外层循环：遍历每个商家分组 -->
      <block wx:for="{{cartList}}" wx:key="merchantId" wx:for-item="shop" wx:for-index="si">
        <view class="shop-group">
          <!-- 商家头部：商家级全选复选框 + 店铺名 + 商品数 -->
          <view class="shop-header">
            <view class="shop-header-left">
              <van-checkbox
                value="{{shop.allSelected}}"
                checked-color="#FF6B35"
                data-merchant-index="{{si}}"
                bind:change="toggleShopSelect"
              />
              <view class="shop-icon-pill">
                <van-icon name="shop-o" size="16px" color="#FF6B35" />
              </view>
              <text class="shop-name">{{shop.shopName}}</text>
            </view>
            <text class="shop-count">{{shop.items.length}} 件商品</text>
          </view>

          <!-- 内层循环：遍历该商家下的每个商品 -->
          <block wx:for="{{shop.items}}" wx:key="id" wx:for-item="item" wx:for-index="ii">
            <view class="cart-item">
              <!-- 单品选中复选框 -->
              <van-checkbox
                value="{{item.selected}}"
                checked-color="#FF6B35"
                data-merchant-index="{{si}}"
                data-item-index="{{ii}}"
                bind:change="toggleSelect"
              />
              <!-- 商品图片：点击跳转商品详情 -->
              <view class="item-clickable" data-goods-id="{{item.goodsId}}" bindtap="goGoodsDetail">
                <van-image src="{{item.mainImage}}" width="96rpx" height="96rpx" radius="18rpx" fit="cover" class="item-img" />
              </view>
              <!-- 商品信息：名称、规格、价格，点击也可跳转详情 -->
              <view class="item-info" data-goods-id="{{item.goodsId}}" bindtap="goGoodsDetail">
                <text class="item-title text-ellipsis-2">{{item.goodsTitle}}</text>
                <text class="item-spec" wx:if="{{item.specName}}">{{item.specName}}</text>
                <view class="item-bottom">
                  <text class="item-price">¥{{item.price}}</text>
                  <!-- 编辑模式：显示删除按钮；正常模式：显示数量步进器 -->
                  <block wx:if="{{editing}}">
                    <van-button size="mini" type="danger" plain data-cart-id="{{item.id}}" bindtap="removeItem">删除</van-button>
                  </block>
                  <block wx:else>
                    <van-stepper
                      value="{{item.quantity}}"
                      min="1"
                      max="99"
                      data-cart-id="{{item.id}}"
                      bind:change="onStepperChange"
                    />
                  </block>
                </view>
              </view>
            </view>
          </block>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 底部操作栏：全选 + 合计/结算（正常模式）或 删除（编辑模式） -->
  <view class="cart-footer" wx:if="{{cartList.length > 0}}">
    <van-checkbox value="{{isAllSelected}}" checked-color="#FF6B35" bind:change="toggleAllSelect">全选</van-checkbox>

    <block wx:if="{{editing}}">
      <view class="footer-right">
        <van-button custom-class="footer-action-btn" type="danger" size="small" bindtap="removeSelected">删除 ({{selectedIds.length}})</van-button>
      </view>
    </block>
    <block wx:else>
      <view class="footer-right">
        <view class="total-info">
          <text class="total-label">合计</text>
          <text class="total-price">¥{{totalPrice}}</text>
        </view>
        <van-button custom-class="footer-action-btn" type="danger" size="small" bindtap="goCheckout" disabled="{{selectedIds.length === 0}}">去结算 ({{totalCount}})</van-button>
      </view>
    </block>
  </view>
</view>

.cart-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.cart-hero {
  padding: calc(24rpx + env(safe-area-inset-top)) 20rpx 0;
}

.cart-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-color);
}

.cart-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.edit-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
}

.cart-summary-card {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 22rpx 20rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)) top right / 180rpx 180rpx no-repeat,
    linear-gradient(145deg, #dd7541 0%, #ea8f57 54%, #f1b76f 100%);
  box-shadow: var(--shadow-floating);
}

.summary-item {
  flex: 1;
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 249, 242, 0.86);
}

.empty-shell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-scroll {
  flex: 1;
  overflow: hidden;
  padding-bottom: 164rpx;
}

.cart-content {
  padding-top: 22rpx;
}

.shop-group {
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 249, 0.98);
  border: 1rpx solid rgba(239, 226, 212, 0.95);
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.shop-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: linear-gradient(180deg, rgba(255, 247, 239, 0.9), rgba(255, 253, 249, 0.95));
}

.shop-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.shop-icon-pill {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
}

.shop-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.cart-item:last-child {
  border-bottom: none;
}

.item-img {
  flex-shrink: 0;
}

.item-clickable {
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.45;
}

.item-spec {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fdf4eb;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.item-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.item-price {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--primary-color);
}

.cart-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 247, 0.96);
  border-top: 1rpx solid rgba(239, 226, 212, 0.92);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.footer-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14rpx;
  min-width: 0;
}

.total-info {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  min-width: 0;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.total-price {
  font-size: 38rpx;
  font-weight: 700;
}

.empty-btn {
  width: 240rpx;
  margin-top: 24rpx;
}

.footer-action-btn {
  width: 100% !important;
  min-width: 0 !important;
  flex: 1 1 260rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

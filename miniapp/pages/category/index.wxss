.category-page {
  display: flex;
  height: 100vh;
  --sidebar-width: 196rpx;
  --sidebar-font-size: 28rpx;
  --sidebar-line-height: 38rpx;
  --sidebar-padding: 18rpx 16rpx 18rpx 12rpx;
  --sidebar-selected-font-weight: 700;
}

.sidebar-wrap {
  width: 196rpx;
  flex-shrink: 0;
  padding: calc(20rpx + env(safe-area-inset-top)) 14rpx 18rpx;
  background: linear-gradient(180deg, #fffaf2 0%, #f3ece4 100%);
  border-right: 1rpx solid rgba(236, 224, 212, 0.9);
  box-shadow: 8rpx 0 24rpx rgba(108, 77, 51, 0.04);
}

.sidebar-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.sidebar-subtitle {
  display: block;
  margin-top: 6rpx;
  margin-bottom: 14rpx;
  font-size: 18rpx;
  line-height: 1.4;
  color: var(--text-secondary);
}

.sidebar {
  height: calc(100vh - 118rpx);
}

.content-area {
  flex: 1;
  height: 100vh;
}

.content-inner {
  padding: calc(20rpx + env(safe-area-inset-top)) 18rpx 30rpx;
}

.category-hero {
  padding-bottom: 28rpx;
}

.hero-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.sub-category-scroll {
  margin-top: 18rpx;
  padding: 10rpx 0;
}

.sub-category-list {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.filter-bar {
  margin-top: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 1rpx solid rgba(239, 226, 212, 0.92);
  box-shadow: var(--shadow-soft);
}

.filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
}

.filter-subtitle {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.filter-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.filter-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fbf4ec;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.category-goods-card {
  width: calc(50% - 8rpx);
  overflow: hidden;
}

.goods-image-wrap {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.goods-chip {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(47, 37, 31, 0.38);
  color: #fff;
  font-size: 20rpx;
}

.goods-info {
  padding: 16rpx 16rpx 18rpx;
}

.goods-shop {
  display: inline-flex;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  color: var(--primary-color);
  font-size: 20rpx;
  font-weight: 700;
}

.goods-title {
  display: block;
  margin-top: 12rpx;
  min-height: 72rpx;
  font-size: 25rpx;
  color: var(--text-color);
  line-height: 1.45;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 30rpx;
}

.goods-sales {
  font-size: 20rpx;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx;
}

.load-more-text {
  font-size: 24rpx;
}

.no-more {
  text-align: center;
  padding: 28rpx 24rpx;
  font-size: 24rpx;
}

.bottom-space {
  height: 50rpx;
}

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 44rpx 60rpx;
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 232, 204, 0.5), rgba(255, 232, 204, 0) 28%),
    linear-gradient(180deg, #dc7642 0%, #ea9056 42%, #f8d4ae 68%, #fbf7f1 100%);
}

.logo-area {
  margin-top: calc(120rpx + env(safe-area-inset-top));
  margin-bottom: 34rpx;
  text-align: center;
}

.logo-icon {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 24rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 18rpx 38rpx rgba(131, 70, 35, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
}

.logo-subtitle {
  font-size: 27rpx;
  color: rgba(255, 248, 242, 0.86);
  letter-spacing: 1rpx;
}

.benefit-list {
  display: flex;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.benefit-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 248, 242, 0.92);
  font-size: 22rpx;
}

.login-form,
.bind-form {
  width: 100%;
  padding: 34rpx 30rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 249, 0.94);
  border: 1rpx solid rgba(255, 243, 231, 0.95);
  box-shadow: var(--shadow-floating);
}

.panel-copy {
  margin-bottom: 28rpx;
}

.bind-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 14rpx;
}

.bind-desc {
  font-size: 25rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  line-height: 1.7;
}

.wx-login-btn {
  height: 92rpx !important;
  font-weight: 700 !important;
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #26c36f, #4fd485) !important;
  border: none !important;
  box-shadow: 0 16rpx 30rpx rgba(47, 169, 98, 0.18) !important;
}

.terms-card {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 247, 237, 0.92);
}

.terms-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

.terms-links {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.terms-link,
.extra-link {
  color: var(--primary-color);
  font-size: 24rpx;
  font-weight: 600;
}

.terms-sep {
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.extra-links,
.bind-bottom-links {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 28rpx;
  margin-top: 22rpx;
}

.bind-btn {
  margin-top: 40rpx;
}

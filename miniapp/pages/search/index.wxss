.search-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.search-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  padding-bottom: 20rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F60 100%);
}

.hero-search {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 245, 0.92);
}

.search-input {
  flex: 1;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 28rpx;
  color: var(--text-color);
}

.search-input-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.cancel-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
}

.search-content {
  flex: 1;
  padding-top: 18rpx;
}

.search-hero {
  margin-bottom: 20rpx;
}

.search-body {
  height: calc(100vh - 330rpx);
}

.search-section {
  margin-bottom: 20rpx;
  padding: 26rpx;
}

.clear-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #faf1e7;
}

.clear-text {
  font-size: 23rpx;
}

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keyword-tag {
  font-size: 25rpx;
  line-height: 1.3;
}

.keyword-tag-hot {
  color: #fff;
}

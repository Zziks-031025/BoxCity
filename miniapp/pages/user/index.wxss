.user-page {
  min-height: 100vh;
  padding-bottom: 56rpx;
}

.user-hero {
  padding: 0 20rpx;
}

.user-card {
  padding: calc(38rpx + env(safe-area-inset-top)) 0 0;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)) top right / 240rpx 240rpx no-repeat,
    linear-gradient(145deg, #dd7541 0%, #eb8f55 48%, #f3bf75 100%);
  border-radius: 0 0 36rpx 36rpx;
  box-shadow: 0 24rpx 56rpx rgba(208, 112, 48, 0.24);
}

.user-info {
  position: relative;
  margin: 0 26rpx;
  padding: 30rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.16);
  box-shadow: 0 12rpx 28rpx rgba(117, 66, 33, 0.12);
}

.avatar-wrap {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  border: 2rpx solid rgba(255, 255, 255, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-detail {
  flex: 1;
  gap: 8rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.phone {
  color: rgba(255, 248, 240, 0.88);
  line-height: 1.6;
}

.arrow-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.quick-summary {
  display: flex;
  gap: 14rpx;
  margin: -22rpx 18rpx 0;
  position: relative;
  z-index: 2;
}

.summary-card {
  flex: 1;
  padding: 22rpx 12rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 249, 0.98);
  border: 1rpx solid rgba(239, 226, 212, 0.95);
  box-shadow: var(--shadow-soft);
  text-align: center;
}

.summary-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.summary-text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.user-content {
  padding-top: 20rpx;
}

.section-card {
  margin-top: 18rpx;
  overflow: hidden;
}

.section-header {
  padding: 28rpx 30rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.order-grid {
  padding: 28rpx 12rpx 24rpx;
}

.order-item {
  flex: 1;
  position: relative;
}

.order-icon-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 14rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff7ef 0%, #fff0df 100%);
  box-shadow: inset 0 0 0 1rpx rgba(237, 198, 162, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff655f, #ff8d67);
  border-radius: 17rpx;
  border: 4rpx solid #fffdf9;
  padding: 0 8rpx;
}

.order-label {
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 600;
}

.menu-section {
  margin-bottom: 18rpx;
}

.menu-list {
  padding: 0 26rpx 6rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #fff2e6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-copy {
  min-width: 0;
}

.menu-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
}

.menu-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

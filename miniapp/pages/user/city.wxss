.city-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.search-card {
  margin: calc(12rpx + env(safe-area-inset-top)) 20rpx 0;
  border-radius: 30rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 1rpx solid rgba(238, 225, 211, 0.98);
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.current-city {
  margin: 14rpx 20rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(255, 253, 249, 0.98);
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(238, 225, 211, 0.98);
  box-shadow: var(--shadow-soft);
}

.loading-wrap {
  padding: 60rpx 0;
}

.search-results,
.province-group {
  margin: 18rpx 20rpx 0;
  background: rgba(255, 253, 249, 0.98);
  border-radius: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(238, 225, 211, 0.98);
  box-shadow: var(--shadow-soft);
}

.search-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.search-item:last-child {
  border-bottom: none;
}

.search-item:active {
  background-color: #fbf3ea;
}

.city-tree {
  margin-top: 2rpx;
}

.province-header {
  padding: 24rpx 28rpx;
  background: linear-gradient(180deg, #fff9f2 0%, #fffdf9 100%);
  border-bottom: 1rpx solid var(--border-color);
}

.province-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.city-list {
  padding: 0 28rpx;
}

.city-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.city-item:last-child {
  border-bottom: none;
}

.city-item:active {
  background-color: #fbf3ea;
}

.city-name {
  font-size: 28rpx;
  color: var(--text-color);
}

.city-name.active {
  color: var(--primary-color);
  font-weight: 700;
}

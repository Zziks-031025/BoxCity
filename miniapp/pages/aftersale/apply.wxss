.aftersale-page {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 196rpx;
}

.card {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 18rpx;
}

.goods-row {
  display: flex;
  gap: 18rpx;
}

.goods-meta {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 10rpx;
}

.goods-name {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.55;
}

.goods-price {
  font-size: 27rpx;
  color: var(--primary-color);
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(240rpx, 320rpx);
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 249, 0.98);
  border-top: 1rpx solid rgba(238, 225, 211, 0.98);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.submit-price {
  font-size: 31rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.submit-action-btn {
  width: 100% !important;
  min-width: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

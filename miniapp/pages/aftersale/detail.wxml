<view class="page-shell aftersale-detail-page" wx:if="{{refund}}">
  <view class="status-card">
    <text class="status-title">{{refund.status === 3 ? '退款成功' : refund.status === 6 ? '售后关闭' : '售后处理中'}}</text>
    <text class="status-desc">{{refund.statusText}}</text>
  </view>

  <view class="card">
    <view class="title">商品信息</view>
    <view class="goods-row">
      <van-image src="{{refund.goodsImage}}" width="80px" height="80px" radius="8px" fit="cover" />
      <view class="goods-meta">
        <text class="goods-name">{{refund.goodsTitle}}</text>
        <text class="goods-price">退款金额 ¥{{refund.refundAmount}}</text>
        <text class="goods-order">订单号 {{refund.orderNo}}</text>
      </view>
    </view>
  </view>

  <view class="com-note order-note">
    <text class="com-note-title">{{testEnvironmentNote.title}}</text>
    <text class="com-note-text">{{testEnvironmentNote.content}}</text>
  </view>

  <view class="card">
    <view class="info-row">
      <text class="label">售后类型</text>
      <text class="value">{{refund.refundType === 1 ? '仅退款' : '退货退款'}}</text>
    </view>
    <view class="info-row">
      <text class="label">退款原因</text>
      <text class="value">{{refund.refundReason}}</text>
    </view>
    <view class="info-row" wx:if="{{refund.rejectReason}}">
      <text class="label">拒绝原因</text>
      <text class="value danger">{{refund.rejectReason}}</text>
    </view>
    <view class="info-row" wx:if="{{refund.logisticsCompany}}">
      <text class="label">退货物流</text>
      <text class="value">{{refund.logisticsCompany}} {{refund.logisticsNo}}</text>
    </view>
  </view>

  <view class="card">
    <view class="title">售后规则说明</view>
    <view class="rule-list">
      <view class="rule-item" wx:for="{{aftersaleRules}}" wx:key="*this">
        <text class="rule-index">{{index + 1}}</text>
        <text class="rule-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{refund.status === 1}}">
    <view class="title">填写退货物流</view>
    <van-field value="{{logisticsCompany}}" label="物流公司" placeholder="请输入物流公司" bind:change="onLogisticsCompanyInput" />
    <van-field value="{{logisticsNo}}" label="物流单号" placeholder="请输入物流单号" bind:change="onLogisticsNoInput" />
    <van-button type="danger" block bindtap="submitReturnLogistics">提交退货物流</van-button>
  </view>

  <view class="card">
    <view class="title">继续处理</view>
    <view class="support-list">
      <view class="support-item" wx:for="{{supportLinks}}" wx:key="title" bindtap="goSupport" data-url="{{item.url}}">
        <view class="support-main">
          <text class="support-title">{{item.title}}</text>
          <text class="support-desc">{{item.desc}}</text>
        </view>
        <van-icon name="arrow" color="#B8A28F" size="24rpx" />
      </view>
    </view>
  </view>

  <view class="action-bar" wx:if="{{refund.status === 0 || refund.status === 4}}">
    <view class="after-action-item" wx:if="{{refund.status === 0}}">
      <van-button custom-class="after-action-btn" plain block size="small" bindtap="cancelRefund">撤销售后申请</van-button>
    </view>
    <view class="after-action-item" wx:if="{{refund.status === 4}}">
      <van-button custom-class="after-action-btn" type="danger" block size="small" bindtap="requestIntervene">申请平台介入</van-button>
    </view>
  </view>
</view>

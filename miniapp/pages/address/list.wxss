.address-page {
  min-height: 100vh;
  padding-bottom: 196rpx;
}

.loading-wrap {
  padding: 48rpx 0;
}

.address-list {
  padding: 18rpx 20rpx 0;
}

.address-item {
  padding: 26rpx 28rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.address-header {
  margin-bottom: 12rpx;
}

.contact-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-right: 18rpx;
}

.contact-phone {
  font-size: 27rpx;
  color: var(--text-secondary);
  margin-right: 14rpx;
}

.default-tag {
  flex-shrink: 0;
}

.address-detail {
  font-size: 26rpx;
  line-height: 1.7;
  margin-bottom: 18rpx;
}

.address-actions {
  padding-top: 18rpx;
  border-top: 1rpx solid var(--border-color);
}

.set-default,
.edit-btn {
  padding: 10rpx 0;
}

.delete-btn {
  width: 140rpx;
  height: 100%;
  background: linear-gradient(135deg, #e16e51, #f08c68);
  color: #fff;
  font-size: 28rpx;
  border-radius: 0 30rpx 30rpx 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 249, 0.98);
  border-top: 1rpx solid rgba(238, 225, 211, 0.98);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.bottom-action-fill {
  width: 100%;
}

.bottom-action-btn {
  width: 100% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

.empty-btn {
  margin-top: 24rpx;
  width: 360rpx;
}

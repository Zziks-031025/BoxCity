.edit-page {
  min-height: 100vh;
  padding-bottom: 196rpx;
}

.form-section,
.default-section {
  margin: 20rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: var(--shadow-soft);
}

.default-section {
  margin-top: 0;
}

.btn-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 249, 0.98);
  border-top: 1rpx solid rgba(238, 225, 211, 0.98);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.bottom-action-fill {
  width: 100%;
}

.bottom-action-btn {
  width: 100% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

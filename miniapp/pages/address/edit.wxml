<view class="page-shell edit-page">
  <view class="form-section">
    <van-cell-group>
      <van-field
        label="收货人"
        value="{{name}}"
        placeholder="请输入收货人姓名"
        bind:change="onNameInput"
        maxlength="20"
        clearable
      />
      <van-field
        label="手机号"
        value="{{phone}}"
        type="number"
        placeholder="请输入手机号"
        bind:change="onPhoneInput"
        maxlength="11"
        clearable
      />
      <van-cell
        title="所在地区"
        value="{{areaText || '请选择省/市/区'}}"
        is-link
        bind:click="openAreaPicker"
      />
      <van-field
        label="详细地址"
        value="{{detail}}"
        type="textarea"
        placeholder="请输入详细地址（街道、楼牌号等）"
        bind:change="onDetailInput"
        maxlength="200"
        autosize
      />
    </van-cell-group>
  </view>

  <view class="default-section">
    <van-cell title="设为默认地址" center>
      <van-switch
        slot="right-icon"
        checked="{{isDefault}}"
        size="24px"
        active-color="#FF6B35"
        bind:change="onDefaultChange"
      />
    </van-cell>
  </view>

  <view class="btn-section">
    <view class="bottom-action-fill">
      <van-button
        custom-class="bottom-action-btn"
        type="primary"
        block
        round
        color="#FF6B35"
        loading="{{loading}}"
        disabled="{{loading}}"
        bind:click="saveAddress"
      >
        保存
      </van-button>
    </view>
  </view>

  <!-- Area Picker Popup -->
  <van-popup
    show="{{showAreaPicker}}"
    position="bottom"
    round
    bind:close="closeAreaPicker"
  >
    <van-area
      title="选择地区"
      area-list="{{areaList}}"
      columns-num="{{3}}"
      value="{{areaValue}}"
      bind:confirm="onAreaConfirm"
      bind:cancel="closeAreaPicker"
    />
  </van-popup>

  <van-toast id="van-toast" />
</view>

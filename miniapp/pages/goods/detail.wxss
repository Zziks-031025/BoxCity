@import "../../styles/commercialization.wxss";

.detail-page {
  padding-bottom: 196rpx;
}

.image-swiper {
  width: 100%;
  height: 760rpx;
}

.image-counter {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 690rpx);
  right: 24rpx;
  z-index: 10;
  background: rgba(47, 37, 31, 0.42);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.info-main,
.merchant-entry,
.desc-card,
.review-card {
  margin: 18rpx 20rpx 0;
  padding: 28rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.goods-price {
  font-size: 60rpx;
}

.goods-original-price {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-decoration: line-through;
}

.goods-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color);
  line-height: 1.5;
}

.goods-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fbf4ec;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.rating-summary {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rating-text {
  font-size: 22rpx;
  color: var(--primary-color);
}

.service-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.service-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: #9a6d2d;
  font-size: 22rpx;
  font-weight: 600;
}

.merchant-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.merchant-avatar-placeholder {
  width: 84rpx;
  height: 84rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #f4be76, #e97840);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 12rpx 24rpx rgba(233, 120, 64, 0.18);
}

.merchant-avatar-placeholder.small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  margin-bottom: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
}

.enter-shop-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  color: var(--primary-color);
  font-size: 24rpx;
}

.card-title-row {
  margin-bottom: 18rpx;
}

.view-all {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.view-all-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.desc-text {
  font-size: 26rpx;
  line-height: 1.8;
}

.rule-note {
  margin-top: 18rpx;
}

.rule-list,
.support-list,
.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rule-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.rule-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary-soft);
  color: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.support-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #fffefb 100%);
  border: 1rpx solid rgba(239, 226, 212, 0.92);
}

.support-main {
  flex: 1;
  min-width: 0;
}

.support-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--text-color);
}

.support-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.review-item {
  border-bottom: 1rpx solid var(--border-color);
  padding-bottom: 24rpx;
}

.review-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.review-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.review-user-info {
  flex: 1;
}

.review-username {
  display: block;
  margin-bottom: 4rpx;
  font-size: 26rpx;
  color: var(--text-color);
}

.review-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.review-content {
  font-size: 26rpx;
  color: #5d4e44;
  line-height: 1.7;
}

.action-bar-placeholder {
  height: 196rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 247, 0.96);
  border-top: 1rpx solid rgba(239, 226, 212, 0.92);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 32rpx rgba(126, 92, 64, 0.08);
}

.quantity-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 10rpx;
  flex-shrink: 0;
  width: 200rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: #fff7f0;
}

.quantity-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  line-height: 1.2;
}

.quantity-stepper {
  width: 100%;
  min-width: 0;
}

.action-btns {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.action-btn {
  width: 100% !important;
  min-width: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  font-size: 28rpx !important;
}

.action-btn-outline,
.action-btn-solid {
  overflow: hidden;
}

.action-policy-block {
  width: 100%;
  padding: 8rpx 6rpx;
}

.action-policy-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
  line-height: 1.5;
}

.action-policy-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

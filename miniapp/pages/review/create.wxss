.review-page {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 196rpx;
}

.card {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.title,
.title-row {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.title {
  margin-bottom: 18rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tip {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.item-card {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 16rpx;
  border: 1rpx solid rgba(236, 225, 214, 0.98);
  border-radius: 20rpx;
  margin-bottom: 14rpx;
  background: #fffaf4;
}

.item-card.active {
  border-color: rgba(233, 125, 67, 0.8);
  background: linear-gradient(180deg, #fff1e6 0%, #fffaf4 100%);
  box-shadow: 0 12rpx 24rpx rgba(231, 136, 74, 0.12);
}

.item-card.disabled {
  opacity: 0.55;
}

.item-main {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 26rpx;
  color: var(--text-color);
  line-height: 1.5;
}

.item-status {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-box,
.upload-box {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(54, 40, 31, 0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.upload-box {
  border: 2rpx dashed rgba(227, 190, 153, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff8f1;
}

.upload-plus {
  font-size: 60rpx;
  color: #c3a38a;
}

.submit-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 20rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 249, 0.98);
  border-top: 1rpx solid rgba(238, 225, 211, 0.98);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 30rpx rgba(111, 83, 58, 0.08);
}

.bottom-action-fill {
  width: 100%;
}

.review-submit-btn {
  width: 100% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
  box-sizing: border-box;
}

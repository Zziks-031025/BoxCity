.review-list-page {
  min-height: 100vh;
  padding: 20rpx;
}

.review-card {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
}

.review-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e7834b, #f0b36d);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.review-main {
  flex: 1;
}

.review-name {
  display: block;
  margin-bottom: 6rpx;
  font-size: 27rpx;
  color: var(--text-color);
}

.review-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.review-content {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  color: var(--text-color);
  line-height: 1.8;
}

.image-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
}
